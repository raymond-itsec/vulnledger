# Core application
APP_VERSION=0.2.2
POSTGRES_USER=change_this_db_user
POSTGRES_PASSWORD=change-this-database-password
POSTGRES_DB=change_this_db_name
POSTGRES_HOST=db
POSTGRES_SERVICE_PORT=5432
FINDINGS_ACCESS_TOKEN_EXPIRE_MINUTES=5
FINDINGS_REFRESH_TOKEN_EXPIRE_DAYS=7
# Optional -- both fall back to code defaults if unset or removed.
# Absolute cap on a refresh-token family: no amount of rotation extends lifetime past this.
# Must be between 7 and 30 inclusive. Default 30.
# FINDINGS_REFRESH_TOKEN_FAMILY_MAX_LIFETIME_DAYS=30
# Forensic retention window for expired/revoked refresh-session rows. Must be
# at least 2 x FINDINGS_REFRESH_TOKEN_FAMILY_MAX_LIFETIME_DAYS. If unset, the
# default is auto-derived (2 x family cap, i.e. 60 days with the default above).
# FINDINGS_REFRESH_SESSION_RETENTION_DAYS=
# Trust Caddy proxy headers for real client IP extraction.
FINDINGS_TRUST_PROXY_HEADERS=true
# CORS hardening (explicit allow-lists, JSON arrays).
FINDINGS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
FINDINGS_ALLOWED_METHODS=["GET","POST","PATCH","DELETE","OPTIONS"]
FINDINGS_ALLOWED_HEADERS=["Authorization","Content-Type","Accept","If-None-Match"]
# Backend log verbosity. DEBUG | INFO | WARNING | ERROR | CRITICAL (case-insensitive).
FINDINGS_LOG_LEVEL=INFO
FINDINGS_RATE_LIMIT_LOGIN=5/minute
FINDINGS_RATE_LIMIT_API=60/minute

# JWT signing (RS256 only).
FINDINGS_JWT_ISSUER=vulnledger-backend
FINDINGS_JWT_AUDIENCE=vulnledger-api
FINDINGS_JWT_PRIVATE_KEY_PEM=
FINDINGS_JWT_PUBLIC_KEY_PEM=
FINDINGS_JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key.pem
FINDINGS_JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key.pem

# Initial admin account (seeded only when the user does not already exist)
FINDINGS_INITIAL_ADMIN_USERNAME=admin
FINDINGS_INITIAL_ADMIN_PASSWORD=change-this-admin-password
FINDINGS_INITIAL_ADMIN_EMAIL=admin@example.com
FINDINGS_INITIAL_ADMIN_FULL_NAME=Administrator

# Storage
SEAWEEDFS_S3_ACCESS_KEY=findings-storage
SEAWEEDFS_S3_SECRET_KEY=change-this-object-storage-secret
FINDINGS_OBJECT_STORAGE_ENDPOINT=seaweedfs:8333
FINDINGS_OBJECT_STORAGE_SECURE=false
FINDINGS_OBJECT_STORAGE_EVIDENCE_BUCKET=finding-attachments
FINDINGS_OBJECT_STORAGE_REPORTS_BUCKET=generated-reports
FINDINGS_ATTACHMENT_MAX_FILE_SIZE_MB=25
FINDINGS_REPORT_MAX_FINDINGS=250
FINDINGS_REPORT_MAX_INPUT_CHARS=200000
FINDINGS_REPORT_MAX_OUTPUT_SIZE_MB=25
FINDINGS_REPORT_RETENTION_DAYS=365

# AV scanner (clamd) - backend connects to this for attachment scanning.
FINDINGS_CLAMAV_HOST=clamav
FINDINGS_CLAMAV_PORT=3310

# Backup container
BACKUP_RETENTION_DAYS=30
BACKUP_CRON=0 2 * * *

# Optional email notifications (Mailjet)
FINDINGS_MAILJET_API_KEY=
FINDINGS_MAILJET_API_SECRET=
FINDINGS_MAILJET_FROM_EMAIL=noreply@findings.local
FINDINGS_MAILJET_FROM_NAME=VulnLedger

# Public URL / TLS host
CADDY_HOST=http://localhost
FINDINGS_APP_BASE_URL=http://localhost

# Auto-generated API documentation. Both default ON. Set false in
# hardened deployments to unmount the URL entirely (FastAPI 404s the
# path). The OpenAPI JSON at /api/v1/openapi.json is always served;
# only the interactive UIs are toggled.
FINDINGS_SWAGGER_UI_ENABLED=true
FINDINGS_REDOC_ENABLED=true

# OIDC optional hardening
FINDINGS_OIDC_ENABLED=false
FINDINGS_OIDC_CLIENT_ID=
FINDINGS_OIDC_CLIENT_SECRET=
FINDINGS_OIDC_DISCOVERY_URL=
FINDINGS_OIDC_REDIRECT_URI=
FINDINGS_OIDC_DEFAULT_ROLE=reviewer
FINDINGS_OIDC_REDIRECT_URI_ALLOWLIST=[]
FINDINGS_OIDC_REQUIRE_NONCE=true

# Optional local port overrides
POSTGRES_PORT=5432
SEAWEEDFS_S3_PORT=8333
BACKEND_PORT=8000
FRONTEND_PORT=5173
CLAMAV_PORT=3310
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_ATTACHMENT_MAX_SIZE=30MB

# Runtime mode / backups
FINDINGS_RUNTIME_MODE=development
BACKUP_ENCRYPTION_SECRET_FILE=/run/secrets/backup_encryption_passphrase
BACKUP_ENCRYPTION_REQUIRED=false

# ---------------------------------------------------------------------
# Observability stack (#27)
# ---------------------------------------------------------------------
# Defaults below are for allinone (single-host) mode. Multihost
# operators set these via deploy/profiles/{multihost-samedc,
# multihost-crossdc}.env or per-host .env overrides.
#
# Image version pins are NOT here - they live in
# deploy/profiles/versions.env (single source of truth, loaded first
# by the Makefile so the matching constraints between vmagent/vmalert/VM
# and loki/promtail can't drift).

# Where vmagents on every tier remote-write metrics. Allinone uses
# Docker DNS; multihost uses vl-monitoring.vuln.lan via /etc/hosts.
VM_REMOTE_WRITE_URL=http://victoriametrics:8428/api/v1/write

# Where promtails on every tier push logs.
LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push

# Grafana admin credentials (REQUIRED - no default; compose fails fast
# with `:?` if absent).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_this_grafana_admin_password

# Grafana served at this URL via caddy reverse-proxy. Must match the
# CADDY_HOST + /grafana/ subpath.
GRAFANA_ROOT_URL=http://localhost:8880/grafana/

# Alertmanager webhook destinations. Both optional - leave empty to
# disable that delivery path. Watchdog deadman heartbeat fires every
# cycle; if the deadman receiver stops hearing it, monitoring is down.
ALERTMANAGER_SLACK_WEBHOOK_URL=
ALERTMANAGER_DEADMAN_WEBHOOK_URL=

# VictoriaMetrics on-disk retention.
VM_RETENTION_MONTHS=12

# Host-port bindings for monitoring services. Defaults bind to 127.0.0.1
# (correct in allinone - cross-tier access goes via Docker DNS).
# Multihost monitoring host overrides these to its private/WG IP.
VM_PORT_BIND=127.0.0.1:8428
LOKI_PORT_BIND=127.0.0.1:3100
ALERTMANAGER_PORT_BIND=127.0.0.1:9093
GRAFANA_PORT_BIND=127.0.0.1:3000
VMALERT_PORT_BIND=127.0.0.1:8881
