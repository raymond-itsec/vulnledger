    "@testing-library/user-event": "^14.5.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "postcss-html": "^1.7.0",
    "stylelint": "^17.11.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
