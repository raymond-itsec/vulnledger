# Multihost profile - SAME-DC mode.
#
# Use this profile when all 4 VulnLedger hosts share the same datacenter
# or rack and have a common private network between them (via the
# provider's private networking, a vSwitch, a private VLAN, or any
# other L2/L3 path). Cross-tier traffic rides that private network;
# WireGuard is optional defense-in-depth, not the primary path.
#
# How services find each other in this mode:
#   - Different VMs / hosts, different Docker daemons.
#   - Cross-VM traffic uses HOST IPs reachable on the shared private
#     network.
#   - Hostnames resolve via /etc/hosts on each VM (templated, identical
#     across all 4 hosts), pointing at the private IPs of each tier.
#
# This file should be loaded BEFORE the project `.env` so any value
# here can be overridden by per-deploy `.env` settings.

# ---------------------------------------------------------------------
# Service discovery - cross-host via /etc/hosts -> private network IPs.
# ---------------------------------------------------------------------
# vl-data.vuln.lan must resolve to the data host's private IP on every
# other host's /etc/hosts. Same for vl-app, vl-edge, vl-monitoring.
POSTGRES_HOST=vl-data.vuln.lan
POSTGRES_SERVICE_PORT=5432
FINDINGS_OBJECT_STORAGE_ENDPOINT=vl-data.vuln.lan:8333
FINDINGS_CLAMAV_HOST=vl-data.vuln.lan
FINDINGS_CLAMAV_PORT=3310

# Caddy on vl-edge reverse-proxies to backend / frontend on vl-app.
CADDY_BACKEND_UPSTREAM=vl-app.vuln.lan:8000
CADDY_FRONTEND_UPSTREAM=vl-app.vuln.lan:5173

# Vite proxy target - frontend talks to backend on the SAME host
# (vl-app). Use Docker DNS within app.yml's compose project.
VITE_API_PROXY_TARGET=http://backend:8000

# ---------------------------------------------------------------------
# Loopback ports for local SSH-into-VM diagnostics.
# ---------------------------------------------------------------------
# Compose still binds these on 127.0.0.1 inside each VM so an SSH
# session to that VM can run `psql` / `curl` directly. The proper
# external entrypoint is Caddy on vl-edge - these loopback bindings
# are not exposed to the network.
POSTGRES_PORT=5432
SEAWEEDFS_S3_PORT=8333
CLAMAV_PORT=3310
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Caddy on vl-edge listens on standard HTTPS via its public NIC.
# Override with whatever port your edge accepts traffic on.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Public URL - the FQDN / IP that DNS or your edge load balancer
# routes to vl-edge.
CADDY_HOST=https://[your-public-fqdn]
FINDINGS_APP_BASE_URL=https://[your-public-fqdn]
