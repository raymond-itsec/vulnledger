# Allinone profile - single host runs all 4 tiers on the same Docker
# daemon. This is what `make allinone-up` loads. Targets the dev box
# (or any single-host install) and reproduces the pre-split behavior
# 1:1 from a service-discovery / port-binding perspective.
#
# How services find each other in this mode:
#   - All on the same Docker daemon, so Docker DNS resolves service
#     names (e.g. `db`, `seaweedfs`, `clamav`, `backend`, `frontend`).
#   - Cross-tier traffic rides the shared compose networks
#     (`frontend_net`, `backend_net`, `data_internal_net`).
#   - Localhost ports are exposed for direct dev access (psql to db,
#     curl to backend, etc.) - NOT exposed to the LAN, only 127.0.0.1.
#
# This file should be loaded BEFORE the project `.env` so that any
# value here can be overridden by per-deploy `.env` settings.

# Service discovery - Docker DNS within the shared compose project.
POSTGRES_HOST=db
POSTGRES_SERVICE_PORT=5432
FINDINGS_OBJECT_STORAGE_ENDPOINT=seaweedfs:8333
FINDINGS_CLAMAV_HOST=clamav
FINDINGS_CLAMAV_PORT=3310

# Caddy upstream targets - Docker DNS within frontend_net bridge.
CADDY_BACKEND_UPSTREAM=backend:8000
CADDY_FRONTEND_UPSTREAM=frontend:5173

# Vite proxy target - Docker DNS within frontend_net.
VITE_API_PROXY_TARGET=http://backend:8000

# Localhost-only port exposure for dev access.
POSTGRES_PORT=5432
SEAWEEDFS_S3_PORT=8333
CLAMAV_PORT=3310
BACKEND_PORT=8000
FRONTEND_PORT=5173
CADDY_HTTP_PORT=8880
CADDY_HTTPS_PORT=8443

# Public URL - generic localhost default. Override in your .env
# (gitignored) with the actual dev-box IP / hostname for LAN access:
#   CADDY_HOST=http://[your-dev-box-ip]:8880
#   FINDINGS_APP_BASE_URL=http://[your-dev-box-ip]:8880
CADDY_HOST=http://localhost:8880
FINDINGS_APP_BASE_URL=http://localhost:8880
