# Observability stack image version pins.
#
# Single source of truth, loaded by every deploy profile (allinone /
# multihost-samedc / multihost-crossdc) via the Makefile. Compose
# substitutes these into the per-tier compose files so the VM trio
# and the Loki/Promtail pair can't drift across tiers.
#
# Each image in compose is referenced as:
#   name:${X_VERSION}${X_IMAGE_DIGEST:-}
# Today the _IMAGE_DIGEST vars are unset, so the ref collapses to
# `name:tag`. When digest pinning lands (#79), each _IMAGE_DIGEST
# gets `@sha256:...` and the same compose line resolves to
# `name:tag@sha256:...` (Docker accepts both).
#
# Matching constraints (DO NOT break):
#   - VM_VERSION  pins victoriametrics + vmagent + vmalert. The three
#                 talk via internal protocols and MUST share a tag.
#                 Their digests after #79 will differ (per-image), but
#                 the tag stays uniform.
#   - LOKI_VERSION pins loki + promtail. The push API is versioned;
#                 mismatched pairs silently drop labels or 400.
#
# Update procedure:
#   1. Bump the version here.
#   2. Resolve the digest for that image and set <NAME>_IMAGE_DIGEST
#      to `@sha256:...` (after #79 lands).
#   3. Single commit: this file + matching CHANGELOG entry.

VM_VERSION=v1.142.0
LOKI_VERSION=3.6.10
ALERTMANAGER_VERSION=v0.32.1
GRAFANA_VERSION=13.0.1
NODE_EXPORTER_VERSION=v1.11.1

# cAdvisor: GitHub releases are at v0.56.x but the upstream container-
# image publishing pipeline stopped at v0.55.1 on gcr.io (likely due
# to Google's gcr.io deprecation in favor of pkg.dev; the project has
# not migrated CI yet). v0.56.x ships as a Linux binary only. Bump
# when upstream resumes publishing images, or fork into a local build
# context if a v0.56.x fix becomes urgent.
CADVISOR_VERSION=v0.55.1

POSTGRES_EXPORTER_VERSION=v0.19.1

# Init-container utility images. No matching constraint with each
# other; bumped on their own cadence. nginx is here for envsubst
# (gettext-tiny is bundled in the alpine variant); busybox provides
# the chown / mkdir one-shots.
NGINX_VERSION=1.30.0-alpine3.23
BUSYBOX_VERSION=1.37.0

# Digest pin slots, populated by #79. Same pattern as the rest.
NGINX_IMAGE_DIGEST=
BUSYBOX_IMAGE_DIGEST=

# Digest pin slots, populated by #79. Leave empty until then; compose
# image refs use `${...:-}` so unset = tag-only behavior.
VICTORIAMETRICS_IMAGE_DIGEST=
VMAGENT_IMAGE_DIGEST=
VMALERT_IMAGE_DIGEST=
LOKI_IMAGE_DIGEST=
PROMTAIL_IMAGE_DIGEST=
ALERTMANAGER_IMAGE_DIGEST=
GRAFANA_IMAGE_DIGEST=
NODE_EXPORTER_IMAGE_DIGEST=
CADVISOR_IMAGE_DIGEST=
POSTGRES_EXPORTER_IMAGE_DIGEST=
