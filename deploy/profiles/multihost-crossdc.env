# Multihost profile - CROSS-DC mode.
#
# Use this profile when the 4 VulnLedger hosts are geographically
# distributed (different datacenters, different cloud regions, or
# different cloud providers entirely). There is no shared private
# network between hosts, so WireGuard is the PRIMARY connectivity
# path, not a defense-in-depth overlay.
#
# How services find each other in this mode:
#   - Each host runs a WireGuard interface; all 4 are peers in a mesh
#     (see deploy/wireguard/ for the helper script).
#   - All cross-tier traffic rides the WG overlay network.
#   - Hostnames resolve via /etc/hosts on each host, pointing at the
#     WG OVERLAY IP of each tier (NOT the public IPs).
#   - Each host's public NIC accepts only WG (UDP 51820) plus, on
#     vl-edge, 80/443. SSH from the operator's admin machine rides WG
#     too (admin host joins the mesh as a 5th peer).
#
# This file should be loaded BEFORE the project `.env` so any value
# here can be overridden by per-deploy `.env` settings.

# ---------------------------------------------------------------------
# Service discovery - cross-host via /etc/hosts -> WG overlay IPs.
# ---------------------------------------------------------------------
# Each hostname resolves to that host's WG overlay IP on every other
# host's /etc/hosts. Public IPs are NOT used for cross-tier traffic.
POSTGRES_HOST=vl-data.vuln.lan
POSTGRES_SERVICE_PORT=5432
FINDINGS_OBJECT_STORAGE_ENDPOINT=vl-data.vuln.lan:8333
FINDINGS_CLAMAV_HOST=vl-data.vuln.lan
FINDINGS_CLAMAV_PORT=3310

# Caddy on vl-edge reverse-proxies to backend / frontend on vl-app
# via the WG overlay - the only path between edge and app in cross-DC.
CADDY_BACKEND_UPSTREAM=vl-app.vuln.lan:8000
CADDY_FRONTEND_UPSTREAM=vl-app.vuln.lan:5173

# Vite proxy target - frontend talks to backend on the SAME host
# (vl-app). Use Docker DNS within app.yml's compose project.
VITE_API_PROXY_TARGET=http://backend:8000

# ---------------------------------------------------------------------
# Bind services to the WG interface, NOT 0.0.0.0.
# ---------------------------------------------------------------------
# In cross-DC mode every host has a public IP (provider-assigned).
# Compose port mappings MUST bind to the host's WG overlay IP so the
# kernel never accepts public connections to backend / postgres /
# seaweedfs / clamav. Set these to the WG overlay IP of THIS host
# (the host running each tier file). Example: if vl-data has WG
# overlay 10.99.0.3, set POSTGRES_PORT=10.99.0.3:5432 in the
# per-deploy .env, not 5432 alone.
#
# Defaults below preserve loopback-only binding (works but offers
# nothing to other hosts on the mesh). Override per host.
POSTGRES_PORT=127.0.0.1:5432
SEAWEEDFS_S3_PORT=127.0.0.1:8333
CLAMAV_PORT=127.0.0.1:3310
BACKEND_PORT=127.0.0.1:8000
FRONTEND_PORT=127.0.0.1:5173

# Caddy on vl-edge listens on the public NIC (the one place inbound
# 80/443 IS allowed). Override if your edge sits behind another LB.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Public URL - the FQDN routed at vl-edge's public IP.
CADDY_HOST=https://[your-public-fqdn]
FINDINGS_APP_BASE_URL=https://[your-public-fqdn]

# ---------------------------------------------------------------------
# Observability stack (#27).
# ---------------------------------------------------------------------
# Cross-DC. vmagents/promtails on every tier push to the monitoring
# host's WG overlay IP. /etc/hosts on each host resolves
# vl-monitoring.vuln.lan to that overlay IP.
#
# Per-host vmagent buffering (--remoteWrite.maxDiskUsagePerURL=1GB)
# absorbs WG link blips up to ~1GB worth of metrics; logs use bounded
# retry (max 50min) before in-flight batches are dropped.
VM_REMOTE_WRITE_URL=http://vl-monitoring.vuln.lan:8428/api/v1/write
LOKI_PUSH_URL=http://vl-monitoring.vuln.lan:3100/loki/api/v1/push

# Bind monitoring services to the host's WG overlay IP. Override on
# the monitoring host's .env to its WG IP (e.g. 10.99.0.4:8428).
# Public NIC must NEVER expose these - WG is the only path.
VM_PORT_BIND=127.0.0.1:8428
LOKI_PORT_BIND=127.0.0.1:3100
ALERTMANAGER_PORT_BIND=127.0.0.1:9093
GRAFANA_PORT_BIND=127.0.0.1:3000
VMALERT_PORT_BIND=127.0.0.1:8881

# Grafana served via caddy on vl-edge.
GRAFANA_ROOT_URL=https://[your-public-fqdn]/grafana/

# Alertmanager webhook destinations - see allinone.env header.
ALERTMANAGER_SLACK_WEBHOOK_URL=https://disabled.invalid/slack
ALERTMANAGER_DEADMAN_WEBHOOK_URL=https://disabled.invalid/deadman

VM_RETENTION_MONTHS=12
