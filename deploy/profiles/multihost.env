# Multihost profile - 4 separate VMs, each running ONE tier's compose
# file. This is what `make multihost-up` deploys (Phase 5+ work).
#
# How services find each other in this mode:
#   - Different VMs, different Docker daemons. Docker DNS only resolves
#     within a single VM's compose project.
#   - Cross-VM traffic uses HOST IPs (the VLAN underlay IPs documented
#     assigned to each VM).
#   - Hostnames resolve via `/etc/hosts` on each VM (templated,
#     identical) - canonical IP per host = the vlan-wg-underlay IP
#     (works without WG, doubles as console fallback).
#
# This file should be loaded BEFORE the project `.env` so that any
# value here can be overridden by per-deploy `.env` settings.

# Service discovery - cross-VM via /etc/hosts → host underlay IPs.
# In this lab the data tier lives on `vl-data` (canonical underlay
# IP 10.40.0.3); for traffic that should specifically ride the
# vlan-backend NIC, use the literal vlan-backend IP 10.30.0.2 instead.
# We use the .vuln.lan hostname here so it survives lab-IP changes
# (just update /etc/hosts on each VM).
POSTGRES_HOST=vl-data.vuln.lan
POSTGRES_SERVICE_PORT=5432
FINDINGS_OBJECT_STORAGE_ENDPOINT=vl-data.vuln.lan:8333
FINDINGS_CLAMAV_HOST=vl-data.vuln.lan
FINDINGS_CLAMAV_PORT=3310

# Caddy upstream targets - reverse-proxy to vl-app over vlan-frontend.
CADDY_BACKEND_UPSTREAM=vl-app.vuln.lan:8000
CADDY_FRONTEND_UPSTREAM=vl-app.vuln.lan:5173

# Vite proxy target - frontend dev preview talks to backend on the
# same VM (vl-app); use Docker DNS within app.yml's compose project.
VITE_API_PROXY_TARGET=http://backend:8000

# In multihost mode, public listening happens on the dev-box-style
# 127.0.0.1 ports too - they let an SSH session into the VM use
# psql / curl directly. The proper external entrypoint is Caddy on
# vl-edge bound to the vlan-public NIC (172.20.1.11), not these
# loopback ports.
POSTGRES_PORT=5432
SEAWEEDFS_S3_PORT=8333
CLAMAV_PORT=3310
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Caddy on vl-edge listens on standard HTTPS port via the vlan-public
# NIC. Override with your enterprise port assignments.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Public URL - whatever DNS / IP the enterprise edge points at vl-edge's
# vlan-public NIC (172.20.1.11). Override per deployment.
CADDY_HOST=https://vl-edge.vuln.lan
FINDINGS_APP_BASE_URL=https://vl-edge.vuln.lan
