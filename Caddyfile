# ---- Global server-level config ----------------------------------------
{
	# Item 14: tighter HTTP timeouts than Caddy defaults to limit DoS surface
	# (slow-loris, idle keep-alive abuse). Values chosen for an interactive
	# SPA: most calls finish in <1s, large attachment uploads need write
	# headroom, idle connections recycle promptly.
	servers {
		timeouts {
			read_body   30s
			read_header 10s
			write       60s
			idle        2m
		}
	}
}

{$CADDY_HOST:http://localhost} {
	encode gzip

	# Baseline edge hardening headers.
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Item 13: modern security headers added below alongside the existing set.
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		# Legacy belt-and-braces alongside the CSP frame-ancestors directive
		# below. Some old user agents only honor X-Frame-Options.
		X-Frame-Options "DENY"
		# Adobe Flash legacy — closes the cross-domain policy file vector.
		X-Permitted-Cross-Domain-Policies "none"
		# Script/style/img/etc. directives are set via SvelteKit's hash-mode
		# CSP meta tag (configured in frontend/svelte.config.js). Only
		# directives that are ignored inside <meta> are emitted here so we
		# don't intersect with and block Kit's inline-script hashes.
		Content-Security-Policy "frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
	}

	@https protocol https
	header @https Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

	# Item 10: do not trust ANY user-supplied forwarding chain. Caddy is the
	# public-facing edge in this deployment; a client should never be able to
	# hint about its IP, host, or scheme. If you ever put Caddy behind another
	# proxy (CDN/ALB), this whole block needs to be inverted to trust the
	# upstream and reject everyone else.
	@spoofed_xff header X-Forwarded-For *
	respond @spoofed_xff "Forbidden" 403
	@spoofed_forwarded header Forwarded *
	respond @spoofed_forwarded "Forbidden" 403
	@spoofed_real_ip header X-Real-IP *
	respond @spoofed_real_ip "Forbidden" 403
	@spoofed_xfh header X-Forwarded-Host *
	respond @spoofed_xfh "Forbidden" 403
	@spoofed_xfp header X-Forwarded-Proto *
	respond @spoofed_xfp "Forbidden" 403
	@spoofed_orig_xff header X-Original-Forwarded-For *
	respond @spoofed_orig_xff "Forbidden" 403
	@spoofed_true_ip header True-Client-IP *
	respond @spoofed_true_ip "Forbidden" 403
	@spoofed_cf_ip header CF-Connecting-IP *
	respond @spoofed_cf_ip "Forbidden" 403
	@spoofed_cluster_ip header X-Cluster-Client-IP *
	respond @spoofed_cluster_ip "Forbidden" 403

	route {
		# VL-2026-005: cap request bodies globally so we can't be flooded with
		# multi-megabyte payloads on JSON endpoints (DoS via memory). Override
		# specifically on the attachments path where larger uploads are
		# legitimate.
		#
		# VL-2026-013: the previous inline path matcher
		# `request_body /api/findings/*/attachments { ... }` did not match the
		# canonical upload path in practice — empirical testing showed the
		# 30MB override only kicked in for paths with trailing extra segments
		# (e.g. /api/findings/<id>/attachments/extra), while real uploads to
		# /api/findings/<id>/attachments fell back to the global 1MB cap and
		# silently 413'd at >1MB.
		#
		# A first attempt at a fix used a no-matcher `request_body 1MB` plus
		# a `@attachments` regexp override at 30MB, but Caddy chains
		# `request_body` middleware: both fire when both match, and the
		# smaller limit wins regardless of order. So the global 1MB cap
		# kept short-circuiting the 30MB cap on attachment requests.
		#
		# Final form: BOTH `request_body` directives carry mutually
		# exclusive matchers, so exactly one fires per request. Anchored
		# regexp (^...$) with a single-segment ID ([^/]+) makes the 30MB
		# cap apply exactly to the canonical upload path and nowhere else.
		# Side benefit: closes the small DoS amplification surface where
		# unauthenticated requests could push 30MB at non-existent routes.
		@attachments path_regexp ^/api/findings/[^/]+/attachments$
		@not_attachments {
			not path_regexp ^/api/findings/[^/]+/attachments$
		}
		request_body @not_attachments {
			max_size 1MB
		}
		request_body @attachments {
			max_size {$CADDY_ATTACHMENT_MAX_SIZE:30MB}
		}

		# Edge API rate limiting (requires caddy-ratelimit module).
		# 1200 events/minute (20/sec average) is comfortable for an SPA that
		# batches requests on page load and stays well above active-dev F5
		# patterns. Endpoints excluded below:
		#   /api/health, /api/health/live  — health probes, must never throttle
		#   /api/auth/refresh              — requires a valid refresh-token cookie,
		#                                    cannot be brute-forced, and a 429 here
		#                                    forcibly logs the user out (catastrophic
		#                                    UX). Brute-force protection lives on
		#                                    /api/auth/login via login_zone below.
		@api_limited {
			path /api/*
			not path /api/health /api/health/live /api/auth/refresh
		}
		rate_limit @api_limited {
			zone api_zone {
				key {remote_host}
				events 1200
				window 1m
			}
		}

		# Tighter bucket specifically on /api/auth/login to keep brute-force
		# protection in place. Only login needs this — /refresh and /logout
		# require an existing valid session (cookie or token) so they can't
		# be brute-forced and fall under the general /api/* limit.
		@login_brute {
			path /api/auth/login
		}
		rate_limit @login_brute {
			zone login_zone {
				key {remote_host}
				events 30
				window 1m
			}
		}

		# Item 3: redirect logged-out users away from protected routes BEFORE
		# the SPA shell loads. Covers both the legacy top-level paths and the
		# /app/* siblings introduced when authenticated routing moved under
		# /app. Redirect target is /login (not /) so the user lands somewhere
		# they can act on.
		@protected_without_session {
			path /clients* /assets* /sessions* /findings* /admin* /templates* /profile*
			path /app/clients* /app/assets* /app/sessions* /app/findings* /app/admin* /app/templates* /app/profile* /app /app/*
			not path /api/*
			not header Cookie *vl_session=1*
		}
		redir @protected_without_session /login 302

		handle /api/* {
			reverse_proxy backend:8000
		}

		handle {
			reverse_proxy frontend:5173
		}
	}
}
