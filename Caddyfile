{$CADDY_HOST:http://localhost} {
	encode gzip

	# Baseline edge hardening headers.
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Script/style/img/etc. directives are set via SvelteKit's hash-mode
		# CSP meta tag (configured in frontend/svelte.config.js). Only
		# directives that are ignored inside <meta> are emitted here so we
		# don't intersect with and block Kit's inline-script hashes.
		Content-Security-Policy "frame-ancestors 'none'"
	}

	@https protocol https
	header @https Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

	# Do not trust user-supplied forwarding chains.
	@spoofed_xff header X-Forwarded-For *
	respond @spoofed_xff "Forbidden" 403
	@spoofed_forwarded header Forwarded *
	respond @spoofed_forwarded "Forbidden" 403

	route {
		request_body /api/findings/*/attachments {
			max_size {$CADDY_ATTACHMENT_MAX_SIZE:30MB}
		}

		# Edge API rate limiting (requires caddy-ratelimit module).
		# 600 events/minute (10/sec average) is comfortable for an SPA that
		# batches requests on page load: a typical dashboard load does ~7
		# parallel calls, and active navigation still leaves plenty of
		# headroom. Anything more sustained than 10 req/sec from a single
		# IP is unusual and worth limiting. Auth endpoints stay covered
		# (a brute-force login would still be capped).
		@api_limited {
			path /api/*
			not path /api/health /api/health/live
		}
		rate_limit @api_limited {
			zone api_zone {
				key {remote_host}
				events 600
				window 1m
			}
		}

		# Tighter bucket specifically on auth endpoints to keep brute-force
		# protection in place even though the general /api/* limit is more
		# permissive. 30 events/min is plenty for legitimate login + token
		# refresh activity.
		@auth_limited {
			path /api/auth/login /api/auth/refresh /api/auth/logout
		}
		rate_limit @auth_limited {
			zone auth_zone {
				key {remote_host}
				events 30
				window 1m
			}
		}

		# Bridge for static SPA mode: avoid loading full protected routes when
		# logged out. Full SSR auth-gating will replace this later.
		@protected_without_session {
			path /clients* /assets* /sessions* /findings* /admin* /templates* /profile*
			not header Cookie *vl_session=1*
		}
		redir @protected_without_session / 302

		handle /api/* {
			reverse_proxy backend:8000
		}

		handle {
			reverse_proxy frontend:5173
		}
	}
}
