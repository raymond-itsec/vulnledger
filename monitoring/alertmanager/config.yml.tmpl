# Alertmanager routing config.
#
# Two routes:
#   1. Default route -> Slack webhook (real alerts).
#   2. Watchdog -> deadman heartbeat URL (always-firing).
#
# Both webhook URLs come from env, set in the operator's `.env` file.
# Empty webhook URL is allowed - the receiver is defined but the
# webhook_configs URL is empty, so Alertmanager logs the would-have-
# been delivery and continues. The operator's own UI inspection
# (Alertmanager at /alertmanager/) will show the firing alerts even
# without external delivery.

global:
  resolve_timeout: 5m

route:
  # Default: send everything to Slack.
  receiver: slack
  group_by: ['alertname', 'service', 'host']
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h

  routes:
    # Watchdog goes to the deadman heartbeat receiver and NOWHERE
    # else. Heartbeat is signal-by-presence; routing it to Slack
    # would just spam.
    - matchers:
        - alertname = "Watchdog"
      receiver: deadman
      group_wait: 0s
      group_interval: 30s
      repeat_interval: 30s

receivers:
  - name: slack
    slack_configs:
      - api_url: ${ALERTMANAGER_SLACK_WEBHOOK_URL}
        channel: '#vulnledger-alerts'
        send_resolved: true
        title: '{{ if eq .Status "firing" }}🚨{{ else }}✅{{ end }} {{ .GroupLabels.alertname }}'
        text: |
          {{ range .Alerts }}
          *{{ .Annotations.summary }}*
          {{ .Annotations.description }}

          Service: `{{ .Labels.service }}`
          Host: `{{ .Labels.host }}`
          Severity: `{{ .Labels.severity }}`
          {{ end }}

  - name: deadman
    webhook_configs:
      - url: ${ALERTMANAGER_DEADMAN_WEBHOOK_URL}
        send_resolved: false

# Inhibit rules suppress lower-priority alerts when a higher-priority
# alert from the same scope is already firing. Example: if the entire
# data tier is down (host-level), suppress the per-service alerts
# (postgres-down, clamav-down, etc.) - they're symptoms, not the
# cause.
inhibit_rules:
  - source_matchers:
      - severity = "critical"
    target_matchers:
      - severity = "warning"
    equal: ['service', 'host']
